{
  "name": "nuxtseo-shared",
  "type": "module",
  "version": "5.1.3",
  "description": "Shared utilities for Nuxt SEO modules.",
  "author": {
    "name": "Harlan Wilton",
    "email": "harlan@harlanzw.com",
    "url": "https://harlanzw.com/"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/harlan-zw",
  "homepage": "https://nuxtseo.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harlan-zw/nuxt-seo.git",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/harlan-zw/nuxt-seo/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "default": "./dist/module.mjs"
    },
    "./content": {
      "types": "./dist/content.d.mts",
      "default": "./dist/content.mjs"
    },
    "./kit": {
      "types": "./dist/kit.d.mts",
      "default": "./dist/kit.mjs"
    },
    "./devtools": {
      "types": "./dist/devtools.d.mts",
      "default": "./dist/devtools.mjs"
    },
    "./i18n": {
      "types": "./dist/i18n.d.mts",
      "default": "./dist/i18n.mjs"
    },
    "./pro": {
      "types": "./dist/pro.d.mts",
      "default": "./dist/pro.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.mts",
      "default": "./dist/utils.mjs"
    },
    "./const": {
      "types": "./dist/const.d.mts",
      "default": "./dist/const.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@nuxt/schema": "^3.16.0 || ^4.0.0",
    "nuxt": "^3.16.0 || ^4.0.0",
    "nuxt-site-config": "^3.2.0 || ^4.0.0",
    "vue": "^3.5.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "nuxt-site-config": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@nuxt/devtools-kit": "4.0.0-alpha.3",
    "@nuxt/kit": "^4.4.2",
    "birpc": "^4.0.0",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "ofetch": "^1.5.1",
    "pathe": "^2.0.3",
    "pkg-types": "^2.3.0",
    "radix3": "^1.1.2",
    "sirv": "^3.0.2",
    "std-env": "^4.0.0",
    "ufo": "^1.6.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxtjs/i18n": "^10.2.4",
    "nuxt-site-config": "^4.0.8",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "scripts": {
    "build": "nuxt-module-build build",
    "dev:prepare": "nuxt-module-build prepare",
    "stub": "nuxt-module-build build --stub",
    "test": "vitest",
    "test:run": "vitest run",
    "test:attw": "attw --pack --profile esm-only",
    "typecheck": "vue-tsc --noEmit"
  }
}